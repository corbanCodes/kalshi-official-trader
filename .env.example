# Kalshi API Credentials
# Get from: https://demo.kalshi.co/account/profile (demo)
#       or: https://kalshi.com/account/profile (production)

KALSHI_API_KEY_ID=your_api_key_id_here

# Private key - paste the ENTIRE key including BEGIN/END lines
# Replace newlines with \n for single-line format
KALSHI_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----

# Set to "true" for real money (default is demo/sandbox)
USE_PRODUCTION=false
